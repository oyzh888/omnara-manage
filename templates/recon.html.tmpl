</div>

<script id="data" type="application/json">__DATA__</script>
<script>
const data = JSON.parse(document.getElementById('data').textContent);
document.getElementById('raw').textContent = JSON.stringify(data, null, 2);
document.getElementById('kpi-total').textContent = data.total_sessions.toLocaleString();
document.getElementById('now').textContent = data.snapshot_at;

// Conversation previews
const pv = document.getElementById('previews');
function esc(t){ return (t||'').replace(/[&<>]/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c])); }
data.previews.forEach(p=>{
  const el = document.createElement('div'); el.className='preview';
  el.innerHTML = `
    <div class="pname">📌 ${esc(p.name)}</div>
    <div class="pid">user_session_id: ${p.usid} · agent_session_id: ${p.asid}
      · <a href="https://www.omnara.com/dashboard/sessions/${p.usid}" target="_blank">open ↗</a></div>
    ${p.msgs.map(m=>`<div class="bubble ${m.sender==='user'?'user':'agent'}">
        <div class="who">${m.sender==='user'?'YOU':'CLAUDE'}</div>
        <div class="txt">${esc(m.text)}</div>
      </div>`).join('')}`;
  pv.appendChild(el);
});

// Sessions table
const container = document.getElementById('sessions');
const head = document.createElement('div');
head.className='session-row';
head.style.background='#1c2128';
head.style.color='var(--mute)';
head.style.fontSize='11px';
head.style.textTransform='uppercase';
head.innerHTML = '<div>name / id</div><div>conn</div><div>work</div><div>last msg</div><div>open</div>';
container.appendChild(head);

function fmt(t){ if(!t) return '—'; const d=new Date(t); const now=new Date(); const m=Math.floor((now-d)/60000); if(m<1) return 'just now'; if(m<60) return m+'m ago'; if(m<24*60) return Math.floor(m/60)+'h ago'; return Math.floor(m/(60*24))+'d ago'; }
function statusTag(s){
  if(!s) return '<span class="tag muted">—</span>';
  const cls = s==='WORKING'||s==='ACTIVE'||s==='CONNECTED'?'ok':s==='IDLE'?'info':s==='AWAITING_INPUT'?'warn':s==='DISCONNECTED'?'err':'muted';
  return `<span class="tag ${cls}">${s}</span>`;
}

function render(rows){
  while(container.children.length>1) container.removeChild(container.lastChild);
  rows.forEach(r=>{
    const row=document.createElement('div');
    row.className='session-row';
    const url = r.session_id ? `https://www.omnara.com/dashboard/sessions/${r.session_id}` : '#';
    row.innerHTML = `
      <div>
        <div class="nm">${r.pinned?'📌 ':''}${esc(r.name||'(unnamed)')}</div>
        <div class="id">${r.session_id} · ${r.model||''} ${r.effort?'· '+r.effort:''} ${r.branch?'· '+esc(r.branch):''}</div>
      </div>
      <div>${statusTag(r.connection_status)}</div>
      <div>${statusTag(r.work_status)}</div>
      <div class="muted">${fmt(r.last_msg||r.created_at)}</div>
      <div><a href="${url}" target="_blank">open ↗</a></div>`;
    container.appendChild(row);
  });
}
render(data.recent);

function filterRows(){
  const q=document.getElementById('filter').value.toLowerCase();
  const filtered = data.recent.filter(r => JSON.stringify(r).toLowerCase().includes(q));
  render(filtered);
}
</script>
</body>
