#!/usr/bin/env python3
"""omnara-mgr — CLI for the omnara-manage skill.

Usage:
    omnara-mgr <action> [args...]

Actions:
    me
    machines
    list [--limit N] [--json]
    show <usid> [--limit N] [--json]
    triage [--json] [--html [--publish]]
    send <usid> <text>            # auto-resolves asid
    launch <wid> <directory> <prompt>
    ensure-workspace <local_path>
    delete <usid>
    raw <METHOD> <path> [json-body]

Reads PAT from $OMNARA_PAT or ~/.omnara/creds.json.
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

HERE = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(HERE))

from omnara_client import OmnaraClient, OmnaraError, load_accounts  # noqa: E402
import triage as triage_mod  # noqa: E402
import summarize as summarize_mod  # noqa: E402
import cf_deploys  # noqa: E402


# ---------- helpers ----------

def _print_json(obj):
    print(json.dumps(obj, indent=2, default=str, ensure_ascii=False))


def _fmt_age(iso: str | None) -> str:
    if not iso:
        return "?"
    from datetime import datetime, timezone
    try:
        d = datetime.fromisoformat(iso.replace("Z", "+00:00"))
    except Exception:
        return "?"
    m = (datetime.now(timezone.utc) - d).total_seconds() / 60
    if m < 60:
        return f"{m:.0f}m"
    if m < 60 * 24:
        return f"{m/60:.1f}h"
    return f"{m/(60*24):.1f}d"


def _resolve_asid(c: OmnaraClient, usid: str) -> str:
    s = c.get_session(usid)
    ag = (s.get("agent_sessions") or [None])[0]
    if not ag:
        raise SystemExit(f"session {usid} has no agent_session")
    return ag["session_id"]


# ---------- commands ----------

def cmd_me(c: OmnaraClient, args):
    me = c.me()
    print(f"user_id : {me.get('id')}")
    print(f"email   : {me.get('email')}")
    print(f"name    : {me.get('display_name') or '-'}")
    print(f"created : {me.get('created_at')}")


def cmd_machines(c: OmnaraClient, args):
    ms = c.machines()
    for m in ms:
        flag = "🟢" if m.get("status") == "ONLINE" else "⚫"
        print(f"{flag}  {m.get('hostname'):<40} id={m.get('id')}  daemon={m.get('daemon_version')}  last_seen={_fmt_age(m.get('last_seen_at'))} ago")


def cmd_list(c: OmnaraClient, args):
    sessions = c.list_sessions()
    if args.json:
        _print_json(sessions[: args.limit])
        return
    for s in sessions[: args.limit]:
        sm = c.session_summary(s)
        flag = "📌 " if sm["pinned"] else ""
        ag_status = sm["work_status"] or "-"
        cn_status = sm["connection_status"] or "-"
        url = c.dashboard_url(sm["usid"])
        print(f"{flag}{sm['name'][:55]:55}  {ag_status:<14} {cn_status:<13} {_fmt_age(sm['last_msg']):>6} ago  {url}")


def cmd_show(c: OmnaraClient, args):
    usid = args.usid
    asid = _resolve_asid(c, usid)
    msgs = c.get_messages(usid, asid, limit=args.limit)
    if args.json:
        _print_json(msgs)
        return
    print(f"== {usid} (agent={asid})")
    for m in msgs:
        content = (m.get("payload") or {}).get("content") or {}
        sender = (m.get("sender") or {}).get("kind", "?")
        t = content.get("type")
        if t == "text":
            text = content.get("text") or ""
            print(f"\n[{sender:14}] {text}")
        else:
            print(f"\n[{sender:14}] <{t}>")


def cmd_send(c: OmnaraClient, args):
    usid = args.usid
    asid = _resolve_asid(c, usid)
    text = args.text
    # By convention, prefix with [from omnara-manage] unless caller already did
    if not text.startswith("[from "):
        text = f"[from omnara-manage] {text}"
    res = c.send_message(usid, asid, text)
    print(f"✅ sent  message_id={res.get('message_id')}  delivery_mode={res.get('delivery_mode')}")
    print(f"    {c.dashboard_url(usid)}")


def cmd_launch(c: OmnaraClient, args):
    res = c.launch_session(args.wid, args.directory, initial_message=args.prompt)
    payload = res.get("payload", res)
    usid = payload.get("user_session_id")
    print(f"✅ launched  user_session_id={usid}")
    if usid:
        print(f"    {c.dashboard_url(usid)}")


def cmd_ensure_workspace(c: OmnaraClient, args):
    if not os.path.isdir(args.local_path):
        # workspaces/ensure requires the path to exist on the daemon machine
        print(f"⚠️  {args.local_path} does not exist locally — Omnara will refuse. mkdir -p first.", file=sys.stderr)
        sys.exit(2)
    ws = c.ensure_workspace(args.local_path)
    print(f"✅ workspace_id={ws['id']}  path={args.local_path}")
    _print_json({"id": ws["id"], "user_machine_paths": ws.get("user_machine_paths", [])})


def cmd_delete(c: OmnaraClient, args):
    c.delete_session(args.usid)
    print(f"✅ deleted {args.usid}")


def cmd_raw(c: OmnaraClient, args):
    body = json.loads(args.body) if args.body else None
    res = c.request(args.method.upper(), args.path, body=body)
    _print_json(res)


def cmd_cf_deploys(c: OmnaraClient, args):
    import argparse as _ap
    if args.subaction == "list":
        cf_deploys.cmd_list(_ap.Namespace())
    elif args.subaction == "prune":
        cf_deploys.cmd_prune(_ap.Namespace(keep=args.keep, dry_run=not args.apply))
    elif args.subaction == "delete":
        if not args.deployment:
            raise SystemExit("--id <deployment> required for delete")
        cf_deploys.cmd_delete(_ap.Namespace(deployment=args.deployment))


# ---------- triage ----------

def _render_triage_html(data: dict, multi: bool = False) -> str:
    name = "dashboard.html.tmpl" if multi else "triage.html.tmpl"
    tmpl_path = HERE / "templates" / name
    return tmpl_path.read_text().replace("__DATA__", json.dumps(data, default=str))


def cmd_sync(c: OmnaraClient, args):
    """End-to-end multi-account triage → write to a tracking repo (clone if needed) →
    git commit + push → optional CF Pages deploy.
    """
    repo_dir = Path(args.repo_dir).expanduser().resolve()
    if not repo_dir.exists():
        if not args.repo_url:
            print(f"⚠️  {repo_dir} does not exist and no --repo-url given", file=sys.stderr)
            sys.exit(2)
        print(f"📥 cloning {args.repo_url} → {repo_dir} ...")
        subprocess.run(["git", "clone", args.repo_url, str(repo_dir)], check=True)

    site_dir = repo_dir / "site"
    data_dir = repo_dir / "data"
    site_dir.mkdir(parents=True, exist_ok=True)
    data_dir.mkdir(parents=True, exist_ok=True)

    # Collect triage across all accounts
    clients = OmnaraClient.all_accounts()
    if not clients:
        print("⚠️  no accounts configured", file=sys.stderr)
        sys.exit(2)
    print(f"🔍 triaging {len(clients)} accounts: {[c.alias for c in clients]}")
    data = triage_mod.triage_multi(clients)

    # Will embed PATs after writing the JSON snapshot (so committed file never sees PATs).
    embedded_pats = None
    if args.embed_pats:
        from omnara_client import load_accounts
        accs = load_accounts()
        embedded_pats = {a["alias"]: a["pat"] for a in accs}
        print(f"🔓 will embed {len(accs)} PATs into the rendered HTML only (not committed JSON)")

    # Optional: LLM summaries
    if args.summarize:
        if not summarize_mod._has_api_key():
            print("⚠️  --summarize set but ANTHROPIC_API_KEY not in env — skipping", file=sys.stderr)
        else:
            print(f"💡 annotating top {args.summarize_top} per bucket with Haiku summaries...")
            summarize_mod.annotate_buckets(data, max_per_bucket=args.summarize_top)

    # Write JSON snapshot (timestamped + latest)
    from datetime import datetime
    ts = datetime.utcnow().strftime("%Y%m%dT%H%M%SZ")
    snap_path = data_dir / f"{ts}.json"
    latest_path = data_dir / "latest.json"
    snap_path.write_text(json.dumps(data, indent=2, default=str))
    latest_path.write_text(json.dumps(data, indent=2, default=str))
    print(f"📝 wrote {snap_path.relative_to(repo_dir)} and data/latest.json")

    # Render dashboard HTML — only the HTML version carries the PATs (if requested)
    data_for_html = dict(data)
    if embedded_pats:
        data_for_html["_embedded_pats"] = embedded_pats
    html = _render_triage_html(data_for_html, multi=True)
    (site_dir / "index.html").write_text(html)
    # Mirror data/ into site/data/ as actual files (wrangler doesn't follow symlinks)
    site_data = site_dir / "data"
    if site_data.is_symlink() or site_data.exists():
        if site_data.is_symlink():
            site_data.unlink()
        else:
            shutil.rmtree(site_data)
    shutil.copytree(data_dir, site_data)
    print(f"📄 rendered site/index.html  ({(site_dir/'index.html').stat().st_size} bytes)")

    # Git commit + push
    if not args.no_git:
        msg = f"sync: triage snapshot {ts} ({sum(len(v) for v in data['buckets'].values())} active across {len(clients)} accounts)"
        for cmd in [
            ["git", "-C", str(repo_dir), "add", "-A"],
            ["git", "-C", str(repo_dir), "-c", "user.email=oyzh888@users.noreply.github.com",
             "-c", "user.name=oyzh888",
             "commit", "-m", msg, "--allow-empty"],
            ["git", "-C", str(repo_dir), "push"],
        ]:
            r = subprocess.run(cmd, capture_output=True, text=True)
            if r.returncode != 0 and "nothing to commit" not in (r.stdout + r.stderr):
                print(f"⚠️  {' '.join(cmd[:4])} failed: {r.stderr.strip()[:200]}", file=sys.stderr)
        print("📤 git push done.")

    # CF Pages deploy
    if args.cf_pages_project:
        if not os.environ.get("CLOUDFLARE_API_TOKEN"):
            print("⚠️  --cf-pages-project set but CLOUDFLARE_API_TOKEN not in env — skipping", file=sys.stderr)
        else:
            r = subprocess.run(
                ["wrangler", "pages", "deploy", str(site_dir), f"--project-name={args.cf_pages_project}"],
                capture_output=True, text=True,
            )
            sys.stdout.write(r.stdout)
            sys.stderr.write(r.stderr)
            # Extract URL from wrangler output
            for line in r.stdout.splitlines():
                if ".pages.dev" in line:
                    print(f"🌐 deployed: {line.strip()}")
                    break


def cmd_accounts(c: OmnaraClient, args):
    accs = load_accounts()
    if not accs:
        print("(none configured) — copy ~/.omnara/creds.json or create ~/.config/omnara-manage/accounts.json")
        return
    for a in accs:
        print(f"  @{a.get('alias','?'):<10} {a.get('email','?'):<30} user_id={a.get('user_id','?')}")


def cmd_triage(c: OmnaraClient, args):
    if args.multi:
        clients = OmnaraClient.all_accounts()
        if not clients:
            print("⚠️  no accounts configured. Add to ~/.config/omnara-manage/accounts.json", file=sys.stderr)
            sys.exit(2)
        data = triage_mod.triage_multi(clients)
    else:
        data = triage_mod.triage(c)
    buckets = data["buckets"]

    if args.json:
        _print_json(data)
        return

    if args.html or args.publish:
        html = _render_triage_html(data)
        out_path = Path(args.out or tempfile.mkdtemp(prefix="omnara-triage-")) / "omnara-triage.html"
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text(html)
        print(f"📄 wrote {out_path}  ({out_path.stat().st_size} bytes)")
        if args.publish:
            if shutil.which("report") is None:
                print("⚠️  `report` CLI not found — install from oyzh888/report-skill, or pass --no-publish", file=sys.stderr)
                sys.exit(2)
            slug = args.slug or "omnara-triage"
            r = subprocess.run(
                ["report", "publish", str(out_path), "--channel", "private-adobe-io", "--slug", slug],
                capture_output=True, text=True,
            )
            sys.stdout.write(r.stdout)
            sys.stderr.write(r.stderr)
            sys.exit(r.returncode)

    # text mode summary
    counts = {k: len(v) for k, v in buckets.items()}
    print(f"\n📋 Omnara triage — {data['total_sessions']} total sessions, {sum(counts.values())} active")
    print(f"   awaiting={counts['awaiting']}  likely={counts['likely_question']}  maybe={counts['maybe_question']}  idle={counts['idle']+counts['agent_should_respond']}\n")

    def print_bucket(title, items, max_n=10):
        if not items:
            return
        print(f"=== {title} ===")
        for r in items[:max_n]:
            print(f"  [score={r['score']:>3}, age={r['age_str']:>6}] {r['name'][:55]}")
            print(f"     {OmnaraClient.dashboard_url(r['usid'])}")
            print(f"     {r['last_text'][-180:].strip().replace(chr(10),' / ')[:180]}")
        if len(items) > max_n:
            print(f"  ... and {len(items)-max_n} more\n")
        else:
            print()

    print_bucket("🚨 URGENT — awaiting_input", buckets["awaiting"])
    print_bucket("🔥 LIKELY needs your decision", buckets["likely_question"])
    print_bucket("💭 MAYBE waiting", buckets["maybe_question"], max_n=5)


# ---------- entry ----------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="omnara-mgr", description="Steve's Omnara fleet butler.")
    sp = p.add_subparsers(dest="action", required=True)

    sp.add_parser("me")
    sp.add_parser("machines")
    sp.add_parser("accounts", help="list configured accounts")

    pl = sp.add_parser("list", help="list recent sessions")
    pl.add_argument("--limit", type=int, default=30)
    pl.add_argument("--json", action="store_true")

    ps = sp.add_parser("show", help="print last messages of a session")
    ps.add_argument("usid")
    ps.add_argument("--limit", type=int, default=20)
    ps.add_argument("--json", action="store_true")

    pt = sp.add_parser("triage", help="score sessions by 'needs Steve'")
    pt.add_argument("--multi", action="store_true", help="merge across all configured accounts")
    pt.add_argument("--json", action="store_true")
    pt.add_argument("--html", action="store_true", help="also write HTML report")
    pt.add_argument("--publish", action="store_true", help="publish HTML via `report publish`")
    pt.add_argument("--out", help="output dir for HTML")
    pt.add_argument("--slug", default="omnara-triage")

    psy = sp.add_parser("sync", help="multi-account triage → tracking repo → git push → optional CF Pages deploy")
    psy.add_argument("--repo-dir", required=True, help="local path to the tracking repo")
    psy.add_argument("--repo-url", help="git URL to clone if --repo-dir doesn't exist")
    psy.add_argument("--cf-pages-project", help="Cloudflare Pages project name to deploy to")
    psy.add_argument("--no-git", action="store_true", help="skip git commit/push")
    psy.add_argument("--summarize", action="store_true", help="add LLM one-liner summaries (needs ANTHROPIC_API_KEY)")
    psy.add_argument("--summarize-top", type=int, default=8, help="how many cards per bucket to summarize")
    psy.add_argument("--embed-pats", action="store_true", help="embed all configured PATs into the page so browser can send messages directly. Only safe on private hosting.")

    pse = sp.add_parser("send", help="send a message into an existing session")
    pse.add_argument("usid")
    pse.add_argument("text")

    pla = sp.add_parser("launch", help="spawn a new session in a workspace")
    pla.add_argument("wid")
    pla.add_argument("directory")
    pla.add_argument("prompt")

    pew = sp.add_parser("ensure-workspace")
    pew.add_argument("local_path")

    pd = sp.add_parser("delete")
    pd.add_argument("usid")

    pr = sp.add_parser("raw", help="any endpoint, any method")
    pr.add_argument("method")
    pr.add_argument("path")
    pr.add_argument("body", nargs="?", help="optional JSON body")

    pcf = sp.add_parser("cf-deploys", help="manage Cloudflare Pages deployment history")
    pcf.add_argument("subaction", choices=["list", "prune", "delete"], help="list / prune (--apply to actually delete) / delete <id>")
    pcf.add_argument("--keep", type=int, default=3, help="prune: keep N newest non-aliased deployments")
    pcf.add_argument("--apply", action="store_true", help="prune: actually delete (default is dry-run)")
    pcf.add_argument("--id", dest="deployment", help="delete: deployment id or 8-char hash")

    return p


HANDLERS = {
    "me": cmd_me,
    "machines": cmd_machines,
    "accounts": cmd_accounts,
    "list": cmd_list,
    "show": cmd_show,
    "triage": cmd_triage,
    "sync": cmd_sync,
    "send": cmd_send,
    "launch": cmd_launch,
    "ensure-workspace": cmd_ensure_workspace,
    "delete": cmd_delete,
    "raw": cmd_raw,
    "cf-deploys": cmd_cf_deploys,
}


def main():
    args = build_parser().parse_args()
    try:
        c = OmnaraClient()
        HANDLERS[args.action](c, args)
    except OmnaraError as e:
        print(f"❌ {e}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
